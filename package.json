{
  "name": "facestudio",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "description": "Private on-device face editor — retouch, restyle, reshape and re-age portraits entirely in your browser.",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview --port 4173",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "@mediapipe/tasks-vision": "0.10.18",
    "delaunator": "5.0.1",
    "gifenc": "1.0.3",
    "onnxruntime-web": "1.20.1",
    "posthog-js": "1.398.0",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "zustand": "5.0.2"
  },
  "devDependencies": {
    "@playwright/test": "1.49.1",
    "@types/delaunator": "5.0.3",
    "@types/react": "18.3.17",
    "@types/react-dom": "18.3.5",
    "@vitejs/plugin-react": "4.3.4",
    "autoprefixer": "10.4.20",
    "postcss": "8.4.49",
    "tailwindcss": "3.4.17",
    "typescript": "5.7.2",
    "vite": "6.0.5",
    "vite-plugin-pwa": "0.21.1",
    "vitest": "3.2.4"
  }
}
